<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z', UTC} %-5level %logger{0} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT" />
  </root>

  <!-- Pekko's typed actor info-level logs are useful at low concurrency but flood the logs at the
       2000+ sessions/sec rate this benchmark targets. Set to WARN. -->
  <logger name="org.apache.pekko" level="WARN" />
</configuration>
