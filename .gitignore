.DS_Store
**/.DS_Store
/.tools/
/target/
**/target/
/results/*
!/results/.gitkeep

# Agent scratch (worktrees, plans, local settings) is not tracked; the
# add-runtime skill is the only intentionally committed .claude/ content.
/.claude/*
!/.claude/skills/

/.venv/
/analysis/.venv/
/services/python-fastapi/.venv/

/services/elixir-phoenix/_build/
/services/elixir-phoenix/cover/
/services/elixir-phoenix/deps/
/services/elixir-phoenix/doc/
/services/elixir-phoenix/.elixir_ls/
/services/typescript-bun/node_modules/
/services/ocaml-oxcaml/_build/
/services/ocaml-oxcaml/_opam/
/services/ocaml-oxcaml-epoll/_build/
/services/ocaml-oxcaml-epoll/_opam/
/services/ocaml-websocket-async/_build/
/services/ocaml-websocket-async/_opam/

# Bazel writes convenience symlinks (`bazel-bin`, `bazel-out`, `bazel-testlogs`,
# `bazel-<workspace>`) into the workspace root. `.tools/` already covers
# bazelisk's launcher; these symlinks are the per-build outputs.
/services/cpp23-uwebsockets/bazel-*

# Generated by `bazel run //:refresh_compile_commands` for clangd / Cursor /
# VSCode IntelliSense. Per-machine: contains absolute paths into the local
# Bazel cache. Regenerate after adding sources or changing copts.
/services/cpp23-uwebsockets/compile_commands.json
/services/cpp23-uwebsockets/external
/services/cpp23-uwebsockets/.cache/

*.log
*.dump
__pycache__/
.pytest_cache/
.ruff_cache/

.env
.env.*
!.env.example
